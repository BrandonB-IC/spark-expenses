*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
*.egg-info/
.pytest_cache/

# Secrets — NEVER commit
.env
credentials.json
token.json
token.backup-*
*.token

# Financial / contractor data
config/contractors.json
config/financial.json
ledger.json

# Generated outputs
reports/
scheduler/logs/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

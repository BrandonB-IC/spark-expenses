# Test fixtures (don't commit real receipts)
tests/fixtures/sample_receipts/*.jpg
tests/fixtures/sample_receipts/*.jpeg
tests/fixtures/sample_receipts/*.png
tests/fixtures/sample_receipts/*.pdf
!tests/fixtures/sample_receipts/.gitkeep

# Test outputs — contain real receipt data (addresses, driver names, merchant locations)
tests/phase*_results.json
tests/phase*_summary.md
tests/phase*_ledger.csv

# Email drafts and other working documents (may contain partner names + working notes)
partner_review_email_draft.md
*_email_draft.md
drafts/

# Dashboard sessions
dashboard/sessions/

# =====================================================================
# Spark Expense Engine — Environment Variables Template
# =====================================================================
# Copy this file to .env and fill in real values. NEVER commit .env.
# =====================================================================

# --- Anthropic (Claude vision OCR) ---
# Same key as your other projects (LINSIGHT, EA). Already exists.
ANTHROPIC_API_KEY=sk-ant-...

# Model for receipt OCR — Haiku is ~10x cheaper for bulk vision work
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001

# --- Google Drive ---
# Path to OAuth client credentials downloaded from Google Cloud Console.
# Use a NEW OAuth client (separate from the EA's tactical-racer-491515-j9 project)
# so a scope-wipe bug here can't break the EA.
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# Drive folder ID of the parent "Spark Expenses" folder.
# Get this from the URL when you open the folder in Drive:
# https://drive.google.com/drive/folders/THIS_LONG_STRING_IS_THE_ID
SPARK_DRIVE_PARENT_FOLDER_ID=

# --- Email delivery (Gmail SMTP) ---
# Reuses the same Gmail app password as the EA — no new setup required.
# Variable names match the EA's scheduler/_common.py convention.
GMAIL_SENDER=brandon@improvement-science.com
GMAIL_APP_PASSWORD=

# --- Report recipients ---
REPORT_RECIPIENT=brandon@improvement-science.com
# Comma-separated list, leave empty for v1
REPORT_CC=

# --- Currency conversion ---
# Free FX API for non-USD receipts
EXCHANGERATE_API_URL=https://api.exchangerate.host

# --- Dashboard ---
# Standalone Flask app port (different from EA's 8765)
DASHBOARD_PORT=8770
